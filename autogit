#!/usr/bin/env bash
# autogit — Main entry point for AutoGit
# Automates common Git workflow operations with i18n support.
#
# Compatible with: bash 4+, zsh 5+
# Author: Sandro Dias <https://github.com/gitdias>
# License: Apache-2.0
# Version: 0.5.0

# ---------------------------------------------------------------------------
# Strict mode — exit on error, undefined variable or pipe failure
# ---------------------------------------------------------------------------
set -euo pipefail

# ---------------------------------------------------------------------------
# Internal constants
# ---------------------------------------------------------------------------
readonly AUTOGIT_VERSION="0.5.0"
readonly AUTOGIT_DIR="${HOME}/.local/bin/autogit"
readonly AUTOGIT_I18N_DIR="${AUTOGIT_DIR}/i18n"
readonly AUTOGIT_MODULES_DIR="${AUTOGIT_DIR}/modules"
readonly AUTOGIT_FALLBACK_LOCALE="en_US"

# ---------------------------------------------------------------------------
# i18n — Locale detection and loading
# ---------------------------------------------------------------------------
_autogit_load_locale() {
    local raw_locale="${LANG:-${LANGUAGE:-${LC_ALL:-}}}"

    local locale
    locale="$(echo "${raw_locale}" | cut -d'.' -f1 | cut -d'@' -f1)"

    if [[ -n "${AUTOGIT_LANG_OVERRIDE:-}" ]]; then
        locale="${AUTOGIT_LANG_OVERRIDE}"
    fi

    local lang_file="${AUTOGIT_I18N_DIR}/${locale}.lang"
    local fallback_file="${AUTOGIT_I18N_DIR}/${AUTOGIT_FALLBACK_LOCALE}.lang"

    if [[ -f "${lang_file}" ]]; then
        # shellcheck source=/dev/null
        source "${lang_file}"
    elif [[ -f "${fallback_file}" ]]; then
        source "${fallback_file}"
        locale="${AUTOGIT_FALLBACK_LOCALE}"
    else
        echo "ERROR: No locale files found in '${AUTOGIT_I18N_DIR}'." >&2
        echo "Please reinstall AutoGit." >&2
        exit 1
    fi

    export AUTOGIT_LOCALE="${locale}"
}

# ---------------------------------------------------------------------------
# Module loader — loads modules without .sh extension
# ---------------------------------------------------------------------------
_autogit_load_module() {
    local module_name="$1"
    local module_file="${AUTOGIT_MODULES_DIR}/${module_name}"

    if [[ ! -f "${module_file}" ]]; then
        echo "ERROR: Module not found: ${module_file}" >&2
        exit 1
    fi

    # shellcheck source=/dev/null
    source "${module_file}"
}

# ---------------------------------------------------------------------------
# Output helpers
# ---------------------------------------------------------------------------
msg_info() {
    printf "[%s] %s\n" "${MSG_INFO}" "$*"
}

msg_warn() {
    printf "[%s] %s\n" "${MSG_WARNING}" "$*" >&2
}

msg_die() {
    printf "[%s] %s\n" "${MSG_ERROR}" "$*" >&2
    exit 1
}

msg_fmt() {
    local template="$1"
    shift
    # shellcheck disable=SC2059
    printf "${template}\n" "$@"
}

# ---------------------------------------------------------------------------
# Dependency checks
# ---------------------------------------------------------------------------
_autogit_check_deps() {
    if ! command -v git &>/dev/null; then
        msg_die "${MSG_GIT_NOT_FOUND}"
    fi
}

# ---------------------------------------------------------------------------
# Git repository guard
# ---------------------------------------------------------------------------
_autogit_require_repo() {
    if ! git rev-parse --git-dir &>/dev/null; then
        msg_die "${MSG_GIT_NOT_REPO}"
    fi
}

# ---------------------------------------------------------------------------
# Global options pre-parser
# Separates global flags from command arguments.
# Populates: AUTOGIT_ARGS (array), AUTOGIT_DRY_RUN, AUTOGIT_LANG_OVERRIDE
# ---------------------------------------------------------------------------
_autogit_parse_globals() {
    # Declare as plain arrays — avoid issues with set -u on empty arrays
    AUTOGIT_ARGS=()
    AUTOGIT_DRY_RUN="false"
    AUTOGIT_LANG_OVERRIDE=""

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --lang|-l)
                shift
                # Guard: --lang requires a value
                if [[ $# -eq 0 ]]; then
                    echo "ERROR: --lang requires a locale argument." >&2
                    exit 1
                fi
                AUTOGIT_LANG_OVERRIDE="$1"
                ;;
            --dry-run)
                AUTOGIT_DRY_RUN="true"
                ;;
            *)
                # Everything else is a command or command argument
                AUTOGIT_ARGS+=("$1")
                ;;
        esac
        shift
    done

    export AUTOGIT_DRY_RUN
    export AUTOGIT_LANG_OVERRIDE
}

# ---------------------------------------------------------------------------
# Help command
# ---------------------------------------------------------------------------
cmd_help() {
    printf "\n%s — v%s\n" "${MSG_HELP_HEADER}" "${AUTOGIT_VERSION}"
    printf "%s\n\n" "${MSG_HELP_USAGE}"
    printf "%s\n" "${MSG_HELP_COMMANDS}"
    printf "  %-16s %s\n" "commit"    "Commit + tag (interativo ou autônomo)"
    printf "  %-16s %s\n" "push"      "Push da branch com validação SSH"
    printf "  %-16s %s\n" "push-tags" "Push de todas as tags locais para o remote"
    printf "  %-16s %s\n" "ssh-setup" "Wizard de configuração SSH (chave, agent, tutorial)"
    printf "  %-16s %s\n" "help"      "${MSG_HELP_FOOTER}"
    printf "  %-16s %s\n" "version"   "Exibe versão do AutoGit"
    printf "\n%s\n" "${MSG_HELP_OPTIONS}"
    printf "%s\n" "${MSG_HELP_OPT_HELP}"
    printf "%s\n" "${MSG_HELP_OPT_LANG}"
    printf "%s\n" "${MSG_HELP_OPT_DRYRUN}"
    printf "\n"
}

# ---------------------------------------------------------------------------
# Version command
# ---------------------------------------------------------------------------
cmd_version() {
    printf "AutoGit v%s\n" "${AUTOGIT_VERSION}"
}

# ---------------------------------------------------------------------------
# Command dispatcher
# Receives the contents of AUTOGIT_ARGS — first element is the command,
# remaining elements are command-specific arguments.
# ---------------------------------------------------------------------------
_autogit_dispatch() {
    # Extract command from first positional argument
    local cmd=""
    if [[ ${#AUTOGIT_ARGS[@]} -gt 0 ]]; then
        cmd="${AUTOGIT_ARGS[0]}"
    fi

    # Build command arguments array (everything after the command)
    local cmd_args=()
    if [[ ${#AUTOGIT_ARGS[@]} -gt 1 ]]; then
        cmd_args=("${AUTOGIT_ARGS[@]:1}")
    fi

    case "${cmd}" in
        "")
            # No command: launch interactive commit wizard
            _autogit_load_module "commit"
            module_commit
            ;;
        commit)
            _autogit_load_module "commit"
            module_commit "${cmd_args[@]+"${cmd_args[@]}"}"
            ;;
        push)
            _autogit_load_module "push"
            module_push "${cmd_args[@]+"${cmd_args[@]}"}"
            ;;
        push-tags)
            # push_tags depends on push SSH helpers — load both
            _autogit_load_module "push"
            _autogit_load_module "push_tags"
            module_push_tags "${cmd_args[@]+"${cmd_args[@]}"}"
            ;;
        ssh-setup)
            _autogit_load_module "ssh_setup"
            module_ssh_setup "${cmd_args[@]+"${cmd_args[@]}"}"
            ;;
        help|-h|--help)
            cmd_help
            ;;
        version|-v|--version)
            cmd_version
            ;;
        *)
            msg_warn "${MSG_UNKNOWN_CMD}: '${cmd}'"
            printf "%s\n" "${MSG_RUN_HELP}"
            exit 1
            ;;
    esac
}

# ---------------------------------------------------------------------------
# Bootstrap — entry point
# ---------------------------------------------------------------------------
main() {
    _autogit_parse_globals "$@"
    _autogit_load_locale
    _autogit_check_deps
    _autogit_dispatch
}

main "$@"